{
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts"],
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "noEmit": true,
    "jsx": "preserve",
    "lib": ["esnext", "dom", "dom.iterable"],
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "next/link": ["./src/lib/next-shims/link.tsx"],
      "next/image": ["./src/lib/next-shims/image.tsx"],
      "next/navigation": ["./src/lib/next-shims/navigation.ts"],
      "next/font/google": ["./src/lib/next-shims/font.ts"],
      "next/headers": ["./src/lib/next-shims/headers.ts"]
    }
  },
  "references": [
    {
      "path": "../../lib/api-client-react"
    }
  ]
}
