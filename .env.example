# ExSell Academy — environment variables
# Copy to `.env` and fill in. Only DATABASE_URL is needed to run prisma;
# the rest are placeholders for later MVP phases (auth, payments, video, storage).

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Database (PostgreSQL) ---
# Used by Prisma (prisma/schema.prisma). Run: npm run db:push
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/exsell?schema=public"

# --- Portal gates (interim, until Clerk) ---
# Shared passwords for the admin and employer preview portals. If unset in
# production, those portals fail closed (no access). Dev defaults exist.
ADMIN_PASSWORD="exsell-admin"
EMPLOYER_PASSWORD="exsell-employer"

# --- Authentication (Clerk — planned) ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
# CLERK_SECRET_KEY=""

# --- Payments (Stripe — planned) ---
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Video hosting (Mux — planned) ---
# MUX_TOKEN_ID=""
# MUX_TOKEN_SECRET=""

# --- File storage (S3 / Cloudflare R2 — planned) ---
# S3_ENDPOINT=""
# S3_REGION=""
# S3_BUCKET=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# --- Email (transactional — planned) ---
# RESEND_API_KEY=""
